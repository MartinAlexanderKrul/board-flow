<?xml version="1.0" encoding="utf-8"?>
<!--
  MainWidget (Glance) — 6 responsive size tiers:
    TINY     ≈ 1×1   (≥50×50 dp)    — game name + camera
    SMALL    ≈ 2×1   (≥100×58 dp)   — branding + game + day + camera
    TALL     ≈ 1×2+  (≥70×120 dp)   — branding + game + players, fills height
    COMPACT  ≈ 3×1   (≥200×58 dp)   — Cinzel header + game·day + camera
    EXPANDED ≈ 3×2+  (≥200×120 dp)  — full session: header + players
    LARGE    ≈ 3×3+  (≥200×230 dp)  — expanded + secondary insight

  minResizeWidth = 50 dp allows 1-cell-wide placement (TINY / TALL tiers).
  Vertical resize lets users reach TALL / EXPANDED / LARGE tiers.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="200dp"
    android:minHeight="58dp"
    android:minResizeWidth="50dp"
    android:minResizeHeight="50dp"
    android:targetCellWidth="3"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_main_loading"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_insights_description" />
