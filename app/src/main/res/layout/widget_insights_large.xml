<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/widget_insights_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/widget_background"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Top row: content + scan button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Logo — hidden by default, shown when wide -->
            <ImageView
                android:id="@+id/widget_insights_logo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/app_logo"
                android:scaleType="fitCenter"
                android:visibility="gone"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/widget_insights_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/widget_insights_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <ImageView
                android:id="@+id/widget_insights_scan"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_widget_camera"
                android:scaleType="fitCenter"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="#33FFFFFF" />

        <!-- Players / scores -->
        <TextView
            android:id="@+id/widget_insights_players"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:lineSpacingExtra="3dp"
            android:maxLines="6"
            android:ellipsize="end" />

        <!-- Divider before hero (always in layout, fades naturally) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:background="#22FFFFFF" />

        <!-- Hero insight excerpt — GONE until a second candidate is available -->
        <TextView
            android:id="@+id/widget_insights_hero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="10sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
